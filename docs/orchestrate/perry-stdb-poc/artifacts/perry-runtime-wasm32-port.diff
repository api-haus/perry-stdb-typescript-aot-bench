index 3309ecc..0767947 100644
--- a/crates/perry-runtime/src/lib.rs
+++ b/crates/perry-runtime/src/lib.rs
@@ -20,9 +20,36 @@
 /// allocation dispatch from ~25-40ns (macOS `malloc`) to ~5-10ns, which is
 /// meaningful because `gc_malloc` is called ~1M+ times/sec in allocation-
 /// heavy workloads (string concat loops, JSON roundtrip, gc_pressure).
+#[cfg(not(target_arch = "wasm32"))]
 #[global_allocator]
 static GLOBAL: mimalloc::MiMalloc = mimalloc::MiMalloc;
 
+// MEASUREMENT (wasm-port): freestanding wasm32 has no mimalloc C build, so
+// route the global allocator through dlmalloc (pure-Rust, wasm-native).
+#[cfg(target_arch = "wasm32")]
+#[global_allocator]
+static GLOBAL: dlmalloc::GlobalDlmalloc = dlmalloc::GlobalDlmalloc;
+
+// MEASUREMENT (wasm-port): getrandom 0.2 refuses wasm32-unknown-unknown
+// without a backend. In a SpacetimeDB module the only entropy source is the
+// host (`ctx.random`); a real port would forward to a host import. This stub
+// is a deterministic placeholder so the core links — NOT a secure RNG.
+#[cfg(target_arch = "wasm32")]
+mod wasm_getrandom {
+    use std::num::NonZeroU32;
+    pub fn fill(buf: &mut [u8]) -> Result<(), getrandom::Error> {
+        // Deterministic fill: a real port replaces this with a host import
+        // (spacetime ctx.random). Returning zeros keeps the ABI honest about
+        // being a stub.
+        for b in buf.iter_mut() {
+            *b = 0;
+        }
+        let _ = NonZeroU32::new(1);
+        Ok(())
+    }
+    getrandom::register_custom_getrandom!(fill);
+}
